# ── Agentic Service Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Express backend URL (default: http://localhost:5000)
BACKEND_BASE_URL=http://localhost:5000

# This service port (default: 8080)
PORT=8080

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Existing ML service URLs (do not change unless ports differ)
DISEASE_API_URL=http://localhost:5050
ML_API_URL=http://localhost:8001

# MongoDB (for future memory module)
# MONGO_URI=mongodb+srv://...

# ── ChromaDB (Module 5) ──────────────────────────────────────────
# CHROMA_DB_DIR=./data/chroma
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# KNOWLEDGE_BASE_DIR=./rag/knowledge_base
# TOP_K_RESULTS=3

# ── External APIs (Module 4) ─────────────────────────────────────
# WEATHER_API_KEY=your_openweathermap_api_key
# WEATHER_API_PROVIDER=openweathermap
# WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
# DEFAULT_LOCATION=Delhi
# REQUEST_TIMEOUT_SECONDS=10

# ── Disease API (Module 6) ───────────────────────────────────────
# DISEASE_API_URL=http://localhost:5050/predict
# DISEASE_CONFIDENCE_THRESHOLD=0.75
# ENABLE_DISEASE_IMAGE_SUPPORT=true

# ── Recommendation API (Module 7) ────────────────────────────────
# RECOMMENDATION_API_URL=http://localhost:8001/predict
# RECOMMENDATION_CONFIDENCE_THRESHOLD=0.70
# DEFAULT_SOIL_TYPE=loamy
# DEFAULT_SEASON=kharif
# ENABLE_RECOMMENDATION_FALLBACK=true

# ── Market API (Module 8) ────────────────────────────────────────
# MARKET_API_URL=http://localhost:5000/api/market/prices
# DEFAULT_MARKET_LOCATION=Delhi
# DEFAULT_MARKET_CROP=Wheat
# MARKET_CONFIDENCE_THRESHOLD=0.70
# ENABLE_MARKET_FALLBACK=true

# ── Escalation API (Module 9) ────────────────────────────────────
# ENABLE_ESCALATION_AGENT=true
# ESCALATION_CONFIDENCE_THRESHOLD=0.65
# DEFAULT_CONSULTANT_TYPE=Agriculture Officer
# DEFAULT_ESCALATION_TARGET=Local Agriculture Department

# ── Memory & Persistence (Module 10) ─────────────────────────────
# ENABLE_MEMORY=true
# MAX_CHAT_HISTORY_MESSAGES=10
# MAX_PROFILE_CROPS=5
# ENABLE_PROFILE_ENRICHMENT=true
# ENABLE_HISTORY_CONTEXT=true

# ── MongoDB (Module 11) ──────────────────────────────────────────
# MONGO_URI=mongodb://localhost:27017
# MONGO_DATABASE=krishi_sakhi
# FARMER_PROFILE_COLLECTION=farmer_profiles
# CONVERSATION_COLLECTION=conversation_messages
# AGENT_INTERACTION_COLLECTION=agent_interactions
# ENABLE_MONGO_MEMORY=true
# MONGO_TIMEOUT_MS=5000

# ── Telemetry & Hindsight (Module 12) ────────────────────────────
# FEEDBACK_COLLECTION=feedback_events
# HINDSIGHT_COLLECTION=hindsight_logs
# TELEMETRY_COLLECTION=telemetry_events
# ENABLE_TELEMETRY=true
# ENABLE_HINDSIGHT_LOGGING=true
# DEFAULT_RESPONSE_SCORE=0.5
# LOW_CONFIDENCE_SCORE_THRESHOLD=0.6

# ── External Hindsight Memory ────────────────────────────────────
# ENABLE_EXTERNAL_HINDSIGHT=true
# HINDSIGHT_PROVIDER=custom
# HINDSIGHT_API_BASE_URL=
# HINDSIGHT_API_KEY=
# HINDSIGHT_PROJECT_ID=
# HINDSIGHT_TIMEOUT_SECONDS=10
# HINDSIGHT_MAX_RETRIES=3
# HINDSIGHT_USE_SDK=false

# ── Background Tasks & Async Events (Module 13) ──────────────────
# ENABLE_BACKGROUND_TASKS=true
# ENABLE_ASYNC_PERSISTENCE=true
# ENABLE_ASYNC_TELEMETRY=true
# ENABLE_ASYNC_FEEDBACK=true
# ENABLE_EVENT_NOTIFICATIONS=true
# BACKGROUND_TASK_TIMEOUT_SECONDS=15
# MAX_BACKGROUND_RETRIES=3

# ── Evaluation Framework & Analytics (Module 14) ─────────────────
# ENABLE_EVALUATION_FRAMEWORK=true
# EVALUATION_REPORTS_DIR=./evaluation/reports
# GOLDEN_DATASET_DIR=./evaluation/datasets
# MIN_ACCEPTABLE_RESPONSE_SCORE=0.65
# MIN_ACCEPTABLE_RAG_SCORE=0.60
# ENABLE_AUTOMATED_EVALUATION=false

# ── Security & Hardening (Module 15) ─────────────────────────────
# ENABLE_AUTH=true
# JWT_SECRET_KEY=replace_me
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=60
# ENABLE_API_KEYS=true
# VALID_API_KEYS=dev-key-1,dev-key-2
# ENABLE_RATE_LIMITING=true
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_REQUEST_SIZE_BYTES=50000
# MAX_MESSAGE_LENGTH=5000
# ENABLE_PII_MASKING=true
# ENABLE_PROMPT_GUARD=true
# ENABLE_INPUT_SANITIZATION=true
